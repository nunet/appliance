{
  "title": "DCGM Exporter",
  "uid": "nunet-dcgm-exporter",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "GPU Utilization %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "local_mimir" },
      "targets": [{ "expr": "avg(DCGM_FI_DEV_GPU_UTIL)", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "GPU Temperature C",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "local_mimir" },
      "targets": [{ "expr": "avg(DCGM_FI_DEV_GPU_TEMP)", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "GPU VRAM Used MiB",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "local_mimir" },
      "targets": [{ "expr": "sum(DCGM_FI_DEV_FB_USED)", "refId": "A" }]
    }
  ]
}
