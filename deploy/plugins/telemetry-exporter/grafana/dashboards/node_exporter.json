{
  "title": "Node Exporter",
  "uid": "nunet-node-exporter",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Utilization %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "local_mimir" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Memory Utilization %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "local_mimir" },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Disk I/O Bytes/s",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "local_mimir" },
      "targets": [
        { "expr": "sum(rate(node_disk_read_bytes_total[2m]))", "legendFormat": "read", "refId": "A" },
        { "expr": "sum(rate(node_disk_written_bytes_total[2m]))", "legendFormat": "write", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network I/O Bytes/s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "local_mimir" },
      "targets": [
        { "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*|br-.*\"}[2m]))", "legendFormat": "rx", "refId": "A" },
        { "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*|br-.*\"}[2m]))", "legendFormat": "tx", "refId": "B" }
      ]
    }
  ]
}
