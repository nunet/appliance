# Common environment file for dev and prod.
# Copy to .env and adjust. Dev defaults are shown; prod can override APPLIANCE_ROOT, ports, CORS, etc.

# Appliance environment profile (startup-scoped)
# Allowed: production | staging
APPLIANCE_ENV=production


# Root of the appliance tree (set to your repo root for dev)
APPLIANCE_ROOT=/home/ubuntu/appliance

# Backend + frontend ports on the box
BACKEND_PORT=8080
FRONTEND_PORT=5173

# Frontend build location when served by FastAPI (dev HMR uses Vite)
NUNET_STATIC_DIR=/home/ubuntu/nunet/appliance/frontend/dist

# Optional data/layout overrides (can be left unset)
NUNET_DATA_DIR=/home/ubuntu/nunet
ENSEMBLES_DIR=/home/ubuntu/ensembles
CONTRACTS_DIR=/home/ubuntu/contracts

# CORS (add your remote IP for Vite dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://remote-ip:5173

# Frontend -> backend override in dev (set when using Vite)
# VITE_API_BASE_URL=http://localhost:8080

# Example DMS-related configuration if needed
# DMS_DEFAULT_CONTEXT=dms
# DMS_INIT_SCRIPT=/home/ubuntu/nunet/appliance/backend/scripts/configure-dms.sh
# DMS_CAP_FILE=/home/ubuntu/.nunet/cap/dms.cap
# SERVICE_DMS_CAP_FILE=/home/nunet/.nunet/cap/dms.cap
# NUNET_CONFIG_PATH=/home/nunet/config/dms_config.json

# Optional staging Ethereum overrides (used only when APPLIANCE_ENV=staging)
# APPLIANCE_STAGING_ETH_CHAIN_ID=11155111
# APPLIANCE_STAGING_ETH_TOKEN_ADDRESS=0xB37216b70a745129966E553cF8Ee2C51e1cB359A
# APPLIANCE_STAGING_ETH_TOKEN_SYMBOL=TSTNTX
# APPLIANCE_STAGING_ETH_TOKEN_DECIMALS=16
# APPLIANCE_STAGING_ETH_EXPLORER_BASE_URL=https://sepolia.etherscan.io/
# APPLIANCE_STAGING_ETH_NETWORK_NAME=Ethereum Sepolia
