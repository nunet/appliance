# Cypress E2E — copy to .env.e2e and adjust.
# Defaults in cypress.config.ts match this: integrated appliance on https://localhost:8443 (same origin).

CYPRESS_ADMIN_PASSWORD=12345678

# Integrated web service (production build, UI + API same origin) — typical for appliance / nunet-web-mode
CYPRESS_BASE_URL=https://localhost:8443
CYPRESS_BACKEND_BASE_URL=https://localhost:8443
CYPRESS_VERIFY_SSL=false
CYPRESS_REBUILD_FRONTEND=true
# Optional: before specs, run ./deploy/scripts/nunet-web-mode.sh rebuild (pnpm build + restart nunet-appliance-web).
# Requires repo layout (deploy/scripts next to frontend/) and sudo for systemctl. Uncomment for integrated 8443 runs.
# CYPRESS_REBUILD_FRONTEND=true
# After Cypress starts (after optional rebuild), wait before running specs so the host can settle (default 30s).
# CYPRESS_RUN_SETTLE_MS=30000
# CYPRESS_RUN_SETTLE_MS=0          # skip wait

# Split dev stack (Vite 5173 + API 8080) — uncomment and use instead of the block above when testing against pnpm dev + dev_backend
# CYPRESS_BASE_URL=http://localhost:5173
# CYPRESS_BACKEND_BASE_URL=http://localhost:8080
# # CYPRESS_VERIFY_SSL not needed for plain HTTP

# Remote appliance (replace host):
# CYPRESS_BASE_URL=https://192.168.1.10:8443
# CYPRESS_BACKEND_BASE_URL=https://192.168.1.10:8443
# CYPRESS_VERIFY_SSL=false

# Optional: setup token location if you do first-time setup in tests
# CYPRESS_SETUP_TOKEN_PATH=/home/ubuntu/.secrets/setup_token

# Optional: Mailhog config for join-org test
# CYPRESS_MAILHOG_BASE_URL=https://mailhog.nunet.network
# CYPRESS_MAIL_INBOX_DOMAIN=mailhog.nunet.network
# CYPRESS_MAIL_SUBJECT_FRAGMENT=Verify your NuNet onboarding request
# CYPRESS_MAILHOG_USERNAME=
# CYPRESS_MAILHOG_PASSWORD=

# Optional: mail polling settings (values in ms)
# CYPRESS_MAIL_POLL_DELAY_MS=30000
# CYPRESS_MAIL_TIMEOUT_MS=600000

# Optional: override spec order
# CYPRESS_SPECS=cypress/e2e/join-org-mailhog.cy.ts,cypress/e2e/offboard-onboard.cy.ts,cypress/e2e/deployments.cy.ts,cypress/e2e/ensembles.cy.ts

# Optional: override test org/role
# CYPRESS_NUTEST_ORG_DID=did:key:z6MksqN98v97yXtaGkuJWeK5yJ9EejZEi6xM19oZa8t4zL5a
# CYPRESS_NUTEST_ROLE=compute_provider


# Optional: increase waits for slow appliances (values in ms)
# CYPRESS_PEER_WAIT_MS=300000
# CYPRESS_PEER_POLL_INTERVAL_MS=5000
# CYPRESS_DEPLOYMENT_DETAIL_WAIT_MS=600000
# CYPRESS_DEPLOYMENT_DETAIL_INTERVAL_MS=5000
# CYPRESS_DEPLOY_REQUEST_TIMEOUT_MS=300000

# Optional: on spec failure, print `journalctl -u nunet-appliance-web.service` (integrated appliance only).
# Uses spec run time from Cypress (stats.startedAt/endedAt): default 10s before start, 60s after end.
# CYPRESS_JOURNAL_ON_FAILURE=0          # disable
# CYPRESS_JOURNAL_SERVICE=nunet-appliance-web.service
# CYPRESS_JOURNAL_BEFORE_SEC=10
# CYPRESS_JOURNAL_AFTER_SEC=60
# CYPRESS_JOURNAL_LINES=120             # fallback if stats timestamps missing
# CYPRESS_JOURNAL_ALL_FAILURES=true     # journal for any failing spec, not only real-appliance-dashboard

# Real-appliance onboard test: DMS may reject onboard when CPU is busy (Cypress + rebuild).
# CYPRESS_SKIP_ONBOARD_E2E=true         # skip the "onboards if needed" test entirely
# CYPRESS_ONBOARD_COOLDOWN_MS=20000     # wait before clicking Onboard (let load drop)
